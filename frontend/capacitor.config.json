{
  "appId": "com.nalamudan.healthtracker",
  "appName": "Nalamudan",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "https://ai-health-tracker-yycb.onrender.com"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "minSdkVersion": 24,
    "targetSdkVersion": 34,
    "buildOptions": {
      "releaseType": "APK"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#1A237E",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_INSIDE",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
